# STT provider: "whisper" or "deepgram"
STT_PROVIDER=whisper

# Deepgram (free credit at deepgram.com)
DEEPGRAM_API_KEY=your_deepgram_key_here

# OpenRouter (free at openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_key_here

# LLM model preference order (fallback chain)
LLM_PRIMARY=google/gemini-flash-1.5
LLM_FALLBACK_1=groq/llama-3.1-70b-versatile
LLM_FALLBACK_2=groq/llama-3.1-8b-instant

# Audio device name (run audio/list_devices.py to find yours)
AUDIO_DEVICE_NAME=CABLE Output (VB-Audio Virtual Cable)

# HuggingFace token (optional, for sentence-transformers model downloads)
HF_TOKEN=

# Server
HOST=localhost
PORT=8765
